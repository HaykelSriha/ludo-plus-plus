{
  "expo": {
    "name": "Ludo++",
    "slug": "ludo-plus-plus",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "ludoplusplus",
    "userInterfaceStyle": "automatic",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false
    },
    "android": {
      "package": "com.ludoplusplus.app"
    },
    "web": {
      "bundler": "metro",
      "output": "static"
    },
    "plugins": [
      "expo-router"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "c819921f-514b-4cbc-a4c7-52b6511b8615"
      }
    }
  }
}
